// --- ANA DÖNGÜ ---
DWORD WINAPI E61GT_Main(LPVOID lpParam) {
    Beep(1000, 500); // Sızma Başarılı!

    while (true) {
        // Menü Tuşu (INSERT)
        if (GetAsyncKeyState(VK_INSERT) & 1) settings.showHUD = !settings.showHUD;

        // İMHA TUŞU (DELETE) - Kanıt bırakmadan hileyi kapatır
        if (GetAsyncKeyState(VK_DELETE) & 1) break;

        CombatEngine();
        RenderEngine();
        MiscEngine();

        Sleep(1); // CPU optimizasyonu
    }

    FreeLibraryAndExitThread((HMODULE)lpParam, 0);
    return 0;
}

// --- SIZMA GİRİŞİ (DLL Entry) ---
BOOL WINAPI DllMain(HMODULE hMod, DWORD sebep, LPVOID res) {
    if (sebep == DLL_PROCESS_ATTACH) {
        DisableThreadLibraryCalls(hMod);
        CreateThread(0, 0, (LPTHREAD_START_ROUTINE)E61GT_Main, hMod, 0, 0);
    }
    return TRUE;
}
