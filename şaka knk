import pyautogui
import keyboard
import time

# Hız limitlerini tamamen kaldır
pyautogui.PAUSE = 0

print("sistem aktif!")
print("BAŞLATMAK için: '1' tuşuna bas")
print("DURDURMAK için: '2' tuşuna bas")
print("PROGRAMDAN ÇIKMAK için: 'ESC' tuşuna bas")

active = False

try:
    while True:
        # Başlatma kontrolü
        if keyboard.is_pressed('1'):
            active = True
            print("\n>>> BAŞLADI!")
            time.sleep(0.2) # Tuşun basılı kalıp sürekli tetiklenmemesi için kısa bir es

        # Durdurma kontrolü
        if keyboard.is_pressed('2'):
            active = False
            print("\n||| DURDURULDU. (Tekrar başlatmak için 1'e bas)")
            time.sleep(0.2)

        # Programdan çıkış
        if keyboard.is_pressed('esc'):
            print("\nProgram kapatılıyor...")
            break

        # Eğer aktifse mesajı gönder
        if active:
            # En hızlı yöntem: Metni yaz ve enterla
            pyautogui.typewrite("heklerim dedim\n")
            
except Exception as e:
    print(f"Bir hata oluştu: {e}")
